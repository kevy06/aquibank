{
  "name": "Flutter Development",
  "image": "ghcr.io/aspect-build/flutter-devcontainer:3.24",
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter"
      ]
    }
  },
  "postCreateCommand": "flutter --version && flutter pub get",
  "forwardPorts": [8080]
}
